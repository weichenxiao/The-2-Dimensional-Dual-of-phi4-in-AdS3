Cell[BoxData[{
 RowBox[{
  RowBox[{"gaDl", "[", 
   RowBox[{"\[CapitalDelta]_", ",", "i_", ",", "j_"}], "]"}], ":=", 
  RowBox[{
   RowBox[{"gaDl", "[", 
    RowBox[{"\[CapitalDelta]", ",", "i", ",", "j"}], "]"}], "=", 
   RowBox[{"Solve", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"Coefficient", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"Block11", "[", 
          RowBox[{"\[CapitalDelta]", ",", "i", ",", "j"}], "]"}], "//.", 
         RowBox[{"Flatten", "[", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"Table", "[", 
             RowBox[{
              RowBox[{"Table", "[", 
