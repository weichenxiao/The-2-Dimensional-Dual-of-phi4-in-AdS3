Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"F2", "[", 
     RowBox[{"n_", ",", "m_"}], "]"}], ":=", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"\[Lambda]", "^", "2"}], "/", 
       RowBox[{"(", 
        RowBox[{"128", 
         RowBox[{"Pi", "^", "4"}]}], ")"}]}], "*", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"4", 
         RowBox[{"Pi", "^", "2"}]}], ")"}], "/", "2"}], 
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         RowBox[{"Schannellog2coeff", "[", 
          RowBox[{"n", ",", "m"}], "]"}], "LLu"}], "+", 
        RowBox[{
         RowBox[{"Schannellog1coeff", "[", 
          RowBox[{"n", ",", "m"}], "]"}], "Lu"}], "+", 
        RowBox[{"Schannellog0coeff", "[", 
         RowBox[{"n", ",", "m"}], "]"}]}], ")"}]}], "/.", 
     "LoopLevelRules"}]}], ";"}], "\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
     RowBox[{"128", 
      RowBox[{"Pi", "^", "4"}]}], "=", 
     RowBox[{
      RowBox[{
       FractionBox["\[Pi]", "2"], 
       SuperscriptBox[
        RowBox[{"(", 
         FractionBox["a", 
          RowBox[{"2", "\[Pi]"}]], ")"}], "4"], 
       FractionBox["1", 
        RowBox[{"4", "\[Pi]a"}]]}], 
      SubscriptBox["|", 
       RowBox[{"a", "=", "1"}]], " ", 
      RowBox[{
      "comes", " ", "from", " ", "normalization", " ", "of", " ", "I4", " ", 
       RowBox[{"(", 
        RowBox[{"Equation", " ", "3.6"}], ")"}], " ", "and", " ", "K4", " ", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"Equation", " ", "4.17"}], ")"}], ".", " ", 
        RowBox[{"\[CapitalGamma]", "[", 
         SubscriptBox["\[CapitalDelta]", "i"], "]"}]}], " ", "in", " ", "the",
        " ", "normalization", " ", "of", " ", "I4", " ", 
       RowBox[{"(", 
        RowBox[{"Equation", " ", "3.6"}], ")"}], " ", "depends", " ", "on", " ",
        "k", " ", "and", " ", "\[Lambda]", " ", "and", " ", "were", " ", 
       "accounted", " ", "for", " ", "when", " ", "summing", " ", "back", " ",
        "the", " ", "infinite", " ", "series", " ", "of", " ", "I4"}]}]}], ",",
     " ", 
    RowBox[{
    "hence", " ", "not", " ", "accounted", " ", "for", " ", "here"}]}], " ", 
   "*)"}], "\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
     RowBox[{"4", 
      RowBox[{"Pi", "^", "2"}]}], "=", 
     RowBox[{
      SuperscriptBox[
       SubscriptBox["N", "\[Phi]"], "2"], " ", "comes", " ", "from", " ", 
      "the", " ", "normalization", " ", "of", " ", "conformal", " ", 
      "block"}]}], ",", " ", 
    RowBox[{"see", " ", "Equation", " ", "2.12"}]}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "2", " ", "is", " ", "the", " ", "symmetry", " ", "factor", " ", "of", " ",
     "one", " ", "loop", " ", "diagram"}], " ", "*)"}]}]}], "Input",
