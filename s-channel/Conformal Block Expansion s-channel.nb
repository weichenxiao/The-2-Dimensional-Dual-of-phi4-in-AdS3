                  RowBox[{"aoDl", "[", 
                   RowBox[{"\[CapitalDelta]", ",", "n", ",", "l"}], "]"}]}], 
                 "}"}], ",", 
                RowBox[{"{", 
                 RowBox[{"l", ",", "0", ",", 
                  RowBox[{
                   RowBox[{"2", 
                    RowBox[{"Abs", "[", 
                    RowBox[{"i", "-", "n"}], "]"}]}], "+", "j"}], ",", "2"}], 
                 "}"}]}], "]"}], ",", 
              RowBox[{"{", 
               RowBox[{"n", ",", "0", ",", 
                RowBox[{"i", "-", "1"}]}], "}"}]}], "]"}], ",", 
            RowBox[{"Table", "[", 
