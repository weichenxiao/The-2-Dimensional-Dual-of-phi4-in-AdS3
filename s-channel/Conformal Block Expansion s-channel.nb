               "}"}], ",", 
              RowBox[{"{", 
               RowBox[{"l", ",", "0", ",", 
                RowBox[{"j", "-", "2"}], ",", "2"}], "}"}]}], "]"}]}], "}"}], 
          "]"}]}], ",", "Lu"}], "]"}], "\[Equal]", 
