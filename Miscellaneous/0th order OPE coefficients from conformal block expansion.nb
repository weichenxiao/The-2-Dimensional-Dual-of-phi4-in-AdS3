Cell[BoxData[{
 RowBox[{"ClearAll", "[", 
  RowBox[{"gaDl", ",", "aoDl"}], "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"aoDl", "[", 
   RowBox[{"\[CapitalDelta]_", ",", "i_", ",", "j_"}], "]"}], ":=", 
  RowBox[{
   RowBox[{"aoDl", "[", 
