                "}"}], ",", 
               RowBox[{"{", 
                RowBox[{"l", ",", "0", ",", 
                 RowBox[{
                  RowBox[{"2", 
                   RowBox[{"Abs", "[", 
                    RowBox[{"i", "-", "n"}], "]"}]}], "+", "j"}], ",", "2"}], 
                "}"}]}], "]"}], ",", 
